ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:3000
# In production set ENVIRONMENT=production and FRONTEND_ORIGIN to your live site URL (no localhost).
LOG_LEVEL=INFO
# Get a key at https://aistudio.google.com/
# Used for RAG chat, voice STT (audio understanding), and voice TTS.
GEMINI_API_KEY=
# Read-scope access token from https://huggingface.co/settings/tokens — needed to
# download the private EmoSens model repo below.
HF_TOKEN=
HF_MODEL_REPO=DSAditya552003/emosense-ai-model
# Render 512Mi (free/starter): LOW_MEMORY_MODE=true + LOAD_EMOTION_MODEL=false.
# Uses keyword RAG/search (no torch). Emotion demo returns 503 until you have 2GB+ RAM.
LOW_MEMORY_MODE=false
DEFER_ML_LOAD=true
LOAD_EMOTION_MODEL=true
